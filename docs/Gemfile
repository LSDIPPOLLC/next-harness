# Local preview only — GitHub Pages builds without this file.
# Pinning the github-pages gem makes a local `bundle exec jekyll serve` match
# what GitHub Pages produces (theme, plugins, and Jekyll versions).
source "https://rubygems.org"

gem "github-pages", group: :jekyll_plugins
gem "jekyll-remote-theme"

# Windows / JRuby timezone data (harmless elsewhere).
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
